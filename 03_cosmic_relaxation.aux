\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces DESI-testable predictions from derived $w(z)$ (Eq.~\ref {eq:w_derived}). \textbf  {(A)} The equation of state $w(z)$ from relaxation dynamics (blue) vs $\Lambda $CDM (dashed). \textbf  {(B)} Percentage departure from $w = -1$; peak $\approx 2.5\%$ at $z \approx 0.55$ with illustrative parameters. \textbf  {(C)} Hubble parameter evolution. \textbf  {(D)} Fractional difference from $\Lambda $CDM ($\lesssim 1\%$). The functional form (localized bump) is \emph  {derived} from the relaxation ansatz; the amplitude is set by $k$, $\beta $, and $\Delta \rho /\rho _\infty $.}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:desi_prediction}{{6}{10}{DESI-testable predictions from derived $w(z)$ (Eq.~\ref {eq:w_derived}). \textbf {(A)} The equation of state $w(z)$ from relaxation dynamics (blue) vs $\Lambda $CDM (dashed). \textbf {(B)} Percentage departure from $w = -1$; peak $\approx 2.5\%$ at $z \approx 0.55$ with illustrative parameters. \textbf {(C)} Hubble parameter evolution. \textbf {(D)} Fractional difference from $\Lambda $CDM ($\lesssim 1\%$). The functional form (localized bump) is \emph {derived} from the relaxation ansatz; the amplitude is set by $k$, $\beta $, and $\Delta \rho /\rho _\infty $}{figure.6}{}}
