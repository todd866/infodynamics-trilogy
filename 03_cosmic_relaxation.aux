\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Dark energy predictions (illustrative). \textbf  {(a)} The equation of state $w(z)$ motivated by relaxation dynamics departs from the $\Lambda $CDM prediction ($w = -1$) around the peak relaxation epoch. \textbf  {(b)} This produces differences in the Hubble parameter evolution potentially detectable by next-generation surveys.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:dark_energy}{{5}{9}{Dark energy predictions (illustrative). \textbf {(a)} The equation of state $w(z)$ motivated by relaxation dynamics departs from the $\Lambda $CDM prediction ($w = -1$) around the peak relaxation epoch. \textbf {(b)} This produces differences in the Hubble parameter evolution potentially detectable by next-generation surveys}{figure.5}{}}
