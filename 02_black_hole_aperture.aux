\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Time dilation from aperture contraction. External observer (red) sees dimensional collapse and time slowing; infalling observer (cyan) maintains constant flow. This demonstrates complementarity-like observer dependence without invoking GR.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:time_dilation}{{1}{6}{Time dilation from aperture contraction. External observer (red) sees dimensional collapse and time slowing; infalling observer (cyan) maintains constant flow. This demonstrates complementarity-like observer dependence without invoking GR}{figure.1}{}}
