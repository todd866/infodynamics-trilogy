\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Schwarzschild comparison. \textbf  {Left}: Time rate $\dot  {\tau }$ vs radius for the aperture model and Schwarzschild prediction. \textbf  {Right}: Direct comparison showing high correlation (see panel title for exact $R^2$). The aperture model reproduces the Schwarzschild curve; however, the fit is partly by construction (see text). The claim is phenomenological correspondence, not derivation.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:schwarzschild}{{3}{8}{Schwarzschild comparison. \textbf {Left}: Time rate $\dot {\tau }$ vs radius for the aperture model and Schwarzschild prediction. \textbf {Right}: Direct comparison showing high correlation (see panel title for exact $R^2$). The aperture model reproduces the Schwarzschild curve; however, the fit is partly by construction (see text). The claim is phenomenological correspondence, not derivation}{figure.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Multi-Observer Complementarity}{8}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Multi-observer complementarity. \textbf  {(A)} Accumulated Fisher time $\tau $ for 21 observers at different radii. Near-horizon observers (purple) accumulate time slowly; distant observers (yellow) accumulate faster; infalling observer (dashed) sees linear time. \textbf  {(B)} Clock rate vs radius on log scale, matching Schwarzschild shape. \textbf  {(C)} Time dilation ratio relative to infalling observer reaches $3\times $. \textbf  {(D)} Snapshots at different times confirm persistent structure.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:complementarity}{{4}{9}{Multi-observer complementarity. \textbf {(A)} Accumulated Fisher time $\tau $ for 21 observers at different radii. Near-horizon observers (purple) accumulate time slowly; distant observers (yellow) accumulate faster; infalling observer (dashed) sees linear time. \textbf {(B)} Clock rate vs radius on log scale, matching Schwarzschild shape. \textbf {(C)} Time dilation ratio relative to infalling observer reaches $3\times $. \textbf {(D)} Snapshots at different times confirm persistent structure}{figure.4}{}}
